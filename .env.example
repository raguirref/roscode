# roscode environment variables — copy to .env and fill in.
# .env is gitignored; .env.example is safe to commit.

# Anthropic API key (required). Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Default workspace path for the agent. CLI flag --workspace overrides this.
# Example: /home/ricar/ros2_ws   or   /workspaces/roscode/demos/demo_drift/workspace
ROSCODE_WORKSPACE=

# Claude model to use. Default uses Opus 4.7 (the hackathon model).
# Override only if you know what you're doing.
ROSCODE_MODEL=claude-opus-4-7

# Max agent loop iterations before forced stop. Default 20.
ROSCODE_MAX_ITERATIONS=20
