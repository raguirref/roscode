  "tokenColors": [
    { "scope": ["comment"], "settings": { "foreground": "#2a3a4a", "fontStyle": "italic" } },
    { "scope": ["string"], "settings": { "foreground": "#a8d8a8" } },
    { "scope": ["constant.numeric", "constant.language"], "settings": { "foreground": "#a78bfa" } },
    { "scope": ["keyword", "storage"], "settings": { "foreground": "#4cc9f0" } },
    { "scope": ["entity.name.function", "support.function"], "settings": { "foreground": "#7ec8e3" } },
    { "scope": ["entity.name.type", "entity.name.class", "support.type"], "settings": { "foreground": "#a78bfa" } },
    { "scope": ["variable.parameter"], "settings": { "foreground": "#c9d1d9" } },
    { "scope": ["punctuation", "meta.brace"], "settings": { "foreground": "#3d4a5c" } },
    { "scope": ["entity.name.tag"], "settings": { "foreground": "#4cc9f0" } },
    { "scope": ["support.variable.property"], "settings": { "foreground": "#8b9ab0" } }
  ]
}
