#!/usr/bin/env bash
# roscode studio CLI launcher — symlink or copy this to /opt/homebrew/bin
# so `roscode-studio .` opens the current dir in the app.

APP="/Applications/roscode studio.app"
CODIUM_BIN="$APP/Contents/Resources/app/bin/codium"

if [ ! -x "$CODIUM_BIN" ]; then
  echo "roscode studio is not installed at $APP" >&2
  echo "Run build-roscode-studio.sh to install it." >&2
  exit 1
fi

exec "$CODIUM_BIN" "$@"
