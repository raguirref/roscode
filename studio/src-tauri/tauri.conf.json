{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "roscode studio",
  "version": "0.1.0",
  "identifier": "com.roscode.studio",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 1400,
        "height": 900,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "AI-native IDE for ROS 2",
    "longDescription": "roscode studio bundles an embedded Linux VM, ROS 2 Humble, and an AI agent powered by Claude Opus 4.7 into a single desktop app. No Docker, no ROS, no Python install required."
  }
}
